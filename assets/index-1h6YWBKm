*{box-sizing:border-box;margin:0;padding:0}body{color:#e2e8f0;scroll-behavior:smooth;background:#020617;font-family:Inter,sans-serif}#root{width:100%}.navbar{-webkit-backdrop-filter:blur(10px);backdrop-filter:blur(10px);z-index:1000;background:#020617e6;border-bottom:1px solid #ffffff0d;justify-content:space-between;align-items:center;padding:20px 80px;display:flex;position:sticky;top:0}.navbar h2{font-weight:600}.nav-links{gap:40px;list-style:none;display:flex}.nav-links a{color:#e2e8f0;text-decoration:none;transition:all .3s;position:relative}.nav-links a:after{content:"";background:#3b82f6;width:0%;height:2px;transition:all .3s;position:absolute;bottom:-5px;left:0}.nav-links a:hover{color:#3b82f6}.nav-links a:hover:after{width:100%}.hero{text-align:center;padding:140px 20px}.hero h1{font-size:4rem;font-weight:600}.hero span{background:linear-gradient(135deg,#3b82f6,#6366f1);-webkit-text-fill-color:transparent;-webkit-background-clip:text}.hero h3{color:#94a3b8;margin-top:10px}.hero p{color:#94a3b8;margin-top:10px;font-size:1.1rem}.hero button{color:#fff;cursor:pointer;background:linear-gradient(135deg,#3b82f6,#6366f1);border:none;border-radius:8px;margin-top:20px;padding:12px 25px;transition:all .3s;box-shadow:0 10px 30px #3b82f64d}.hero button:hover{transform:scale(1.05)}.socials{margin-top:15px}.socials a{color:#3b82f6;margin:0 10px;text-decoration:none}.section{max-width:1100px;margin:auto;padding:80px}.section h2{margin-bottom:20px;font-size:2rem}#about p{color:#cbd5f5;max-width:700px;margin-top:10px;font-size:1.2rem;line-height:1.8}.skills-container{grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:25px;display:grid}.skill-card{text-align:center;-webkit-backdrop-filter:blur(12px);backdrop-filter:blur(12px);background:#ffffff08;border:1px solid #ffffff1a;border-radius:20px;padding:30px;transition:all .3s}.skill-card:hover{border-color:#3b82f6;transform:translateY(-10px)scale(1.05);box-shadow:0 10px 25px #3b82f633}.projects-container{grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:40px;display:grid}.card{-webkit-backdrop-filter:blur(10px);backdrop-filter:blur(10px);background:#ffffff0d;border:1px solid #ffffff14;border-radius:16px;padding:30px;transition:all .3s}.card:hover{transform:translateY(-12px)scale(1.02);box-shadow:0 20px 40px #3b82f64d}.card img{border-radius:12px;width:100%;margin-bottom:10px}.card a{color:#3b82f6;text-decoration:none}.section p{margin-top:10px}@media (width<=768px){.navbar{padding:20px}.nav-links{gap:20px;font-size:14px}.hero h1{font-size:2.5rem}.section{padding:40px 20px}}
